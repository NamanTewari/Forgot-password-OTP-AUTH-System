<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <main class="page-shell">
        <section class="auth-card">
            <div class="brand-row">
                <div class="brand-mark">O</div>
                <div>
                    <p class="eyebrow">Password help</p>
                    <h1>Get your OTP</h1>
                </div>
            </div>
            <p class="lead">Enter your registered email and we will generate a one-time password for verification.</p>

            <form class="form-grid" action="/forgot-password" method="POST">
                <div class="field">
                    <label for="email">Email address</label>
                    <input id="email" name="email" type="email" placeholder="you@example.com" required>
                </div>
                <button class="button" type="submit">Send OTP</button>
            </form>

            <p class="footer-note">Remembered it? <a href="/login">Back to login</a></p>
        </section>
    </main>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <main class="page-shell">
        <section class="auth-card">
            <div class="brand-row">
                <div class="brand-mark">R</div>
                <div>
                    <p class="eyebrow">Final step</p>
                    <h1>Reset password</h1>
                </div>
            </div>
            <p class="lead">Choose a fresh password and return to a secure login.</p>

            <form class="form-grid" action="/reset-password" method="POST">
                <div class="field">
                    <label for="email">Email address</label>
                    <input id="email" name="email" type="email" value="<%= typeof email !== 'undefined' ? email : (typeof queryEmail !== 'undefined' ? queryEmail : '') %>" placeholder="you@example.com" required>
                </div>
                <div class="field">
                    <label for="password">New password</label>
                    <input id="password" name="password" type="password" placeholder="Enter new password" required>
                </div>
                <button class="button" type="submit">Update password</button>
            </form>

            <p class="footer-note"><a href="/login">Return to login</a></p>
        </section>
    </main>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <main class="page-shell">
        <section class="auth-card">
            <div class="brand-row">
                <div class="brand-mark">S</div>
                <div>
                    <p class="eyebrow">Secure access</p>
                    <h1>Sign in</h1>
                </div>
            </div>
            <p class="lead">Enter your credentials to continue to your dashboard.</p>

            <form class="form-grid" action="/login" method="POST">
                <div class="field">
                    <label for="email">Email address</label>
                    <input id="email" name="email" type="email" placeholder="you@example.com" required>
                </div>
                <div class="field">
                    <label for="password">Password</label>
                    <input id="password" name="password" type="password" placeholder="Enter your password" required>
                </div>
                <div class="split-actions">
                    <span>Need a reset?</span>
                    <a href="/forgot-password">Forgot password</a>
                </div>
                <button class="button" type="submit">Login</button>
            </form>

            <p class="footer-note">New here? <a href="/register">Create an account</a></p>
        </section>
    </main>
</body>
</html>

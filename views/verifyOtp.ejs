<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <main class="page-shell">
        <section class="auth-card">
            <div class="brand-row">
                <div class="brand-mark">6</div>
                <div>
                    <p class="eyebrow">Verification</p>
                    <h1>Enter OTP</h1>
                </div>
            </div>
            <p class="lead">Use the six-digit code generated for your account. It expires in 5 minutes.</p>

            <form class="form-grid" action="/verify-otp" method="POST">
                <div class="field">
                    <label for="email">Email address</label>
                    <input id="email" name="email" type="email" value="<%= typeof email !== 'undefined' ? email : (typeof queryEmail !== 'undefined' ? queryEmail : '') %>" placeholder="you@example.com" required>
                </div>
                <div class="field">
                    <label for="otp">OTP code</label>
                    <input class="otp-input" id="otp" name="otp" type="text" inputmode="numeric" maxlength="6" pattern="[0-9]{6}" placeholder="000000" required>
                </div>
                <button class="button" type="submit">Verify OTP</button>
            </form>

            <p class="footer-note">Need a new code? <a href="/forgot-password">Generate again</a></p>
        </section>
    </main>
</body>
</html>
